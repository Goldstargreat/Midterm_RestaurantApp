<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2E7D32"
            android:padding="20dp"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️ 나의 맛집 리스트"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />
            <TextView
                android:id="@+id/tv_selected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="카테고리를 선택하고 맛집을 추가하세요"
                android:textSize="14sp"
                android:textColor="#C8E6C9" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="15dp">
            <Button
                android:id="@+id/btn_cat_all"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="전체"
                android:layout_margin="2dp"/>
            <Button
                android:id="@+id/btn_cat_korean"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="한식"
                android:layout_margin="2dp"/>
            <Button
                android:id="@+id/btn_cat_china"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="중식"
                android:layout_margin="2dp"/>
            <Button
                android:id="@+id/btn_cat_japanese"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="일식"
                android:layout_margin="2dp"/>
            <Button
                android:id="@+id/btn_cat_western"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="양식"
                android:layout_margin="2dp"/>
            <Button
                android:id="@+id/btn_cat_etcetra"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="기타"
                android:layout_margin="2dp"/>

        </LinearLayout>

        <Spinner
            android:id="@+id/sp_restaurant"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/btn_round"
            android:layout_marginBottom="15dp"
            android:padding="10dp"
            android:elevation="2dp" />
        <Button
            android:id="@+id/btn_detail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="🔍 상세보기"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp">

            <EditText
                android:id="@+id/et_restaurant"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="맛집 이름을 입력하세요"
                android:paddingLeft="12dp"
                android:background="#F9FBE7"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_number"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="전화번호를 입력하세요"
                android:inputType="phone"
                android:paddingLeft="12dp"
                android:background="#F9FBE7"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="카테고리 선택"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <RadioGroup
                android:id="@+id/rg_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

<!--                <RadioButton-->
<!--                    android:id="@+id/rb_chicken"-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_weight="1"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="치킨"-->
<!--                    android:checked="true"/>-->
<!--                <RadioButton-->
<!--                    android:id="@+id/rb_pizza"-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_weight="1"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="피자"-->
<!--                    android:checked="true"/>-->
<!--                <RadioButton-->
<!--                    android:id="@+id/rb_hamburger"-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_weight="1"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="햄버거"-->
<!--                    android:checked="true"/>-->
                <RadioButton
                    android:id="@+id/rb_korean"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="한식"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb_china"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="중식"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb_japanese"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="일식"/>
                <RadioButton
                    android:id="@+id/rb_western"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="양식"/>
                <RadioButton
                    android:id="@+id/rb_etcetera"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="기타"/>

            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btn_add"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="＋ 추가"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#388E3C"
                    android:layout_marginEnd="6dp" />
                <Button
                    android:id="@+id/btn_delete"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="− 삭제"
                    android:textColor="#C62828"
                    android:backgroundTint="#FFEBEE"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>